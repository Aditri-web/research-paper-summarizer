# =============================================================================
# .gitignore — Research Paper Summarizer
# =============================================================================

# Python
venv/
env/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# Secrets & credentials
.env
kaggle.json
hf_token.txt
*.key

# --- Large model files (never commit these) ---
models/
*.bin
*.safetensors
*.pt
*.pth
*.gguf
*.ggml

# LoRA adapter files (tracked separately via HF Hub)
adapter_model.bin
adapter_model.safetensors

# --- Training outputs ---
outputs/
wandb/
runs/
checkpoints/
results/
*.log

# --- AlignScore checkpoint (large) ---
alignscore_ckpt/

# --- Data (large files, use HF Hub instead) ---
data/raw/
data/cache/
data/processed/
data/cnn_dailymail_cached/
data/data/

# Specific large files
data/data/arxiv-metadata-oai-snapshot.json
data/data/arxiv.zip
data/data/*.json
data/data/*.zip
*.arrow
*.parquet

# --- Dataset cache ---
~/.cache/huggingface/

# Dev / IDE
.idea/
.vscode/
*.swp
*.swo

# Coverage
.coverage
htmlcov/
.pytest_cache/
